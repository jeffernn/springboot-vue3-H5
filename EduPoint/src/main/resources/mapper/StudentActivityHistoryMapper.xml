<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.edupoint.mapper.StudentActivityHistoryMapper">
    <update id="updatePosterByActivityName">
        UPDATE t_student_activity_history
        SET poster = #{poster}
        WHERE activity_name = #{activityName}
    </update>
</mapper>